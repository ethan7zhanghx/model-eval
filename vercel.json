{
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/llm-proxy.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/zhumengdao-monitor",
      "schedule": "0 1 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/zhumengdao/(.*)",
      "destination": "/zhumengdao/$1"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/under-construction.html",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/under-construction.html",
      "permanent": false
    }
  ]
}
